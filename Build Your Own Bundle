<section id="custom-bundle" class="pricing-section" style="padding: 60px 20px; background-color: #fdfdfd; direction: rtl; font-family: 'Tajawal', sans-serif;">
    <div class="container" style="max-width: 800px; margin: 0 auto; text-align: center;">
        <h2 style="color: #4a4a4a; margin-bottom: 20px;">صمّم باقتك الخاصة من إيفال</h2>
        <p style="color: #777; margin-bottom: 40px;">اختر الأدوات التي تناسب احتياجاتك الآن، واحصل على خصم 15% عند اختيار أداتين أو أكثر.</p>

        <div id="tools-list" style="text-align: right; margin-bottom: 30px;">
            </div>

        <div id="price-summary" style="background: #fff; padding: 20px; border-radius: 12px; border: 1px solid #eee; margin-bottom: 30px; display: none;">
            <p id="total-price" style="font-size: 1.2rem; color: #444;"></p>
            <p id="discount-price" style="font-size: 1.4rem; color: #e67e22; font-weight: bold;"></p>
        </div>

        <button id="send-request-btn" onclick="openRequestForm()" style="background-color: #4a4a4a; color: #fff; padding: 15px 40px; border: none; border-radius: 8px; font-size: 1.1rem; cursor: pointer; display: none;">
            إرسال طلب الباقة المخصصة
        </button>
    </div>
</section>

<script>
const evalTools = [
    { id: 1, name: "أجندة إيفال (360 يوم)", price: 35 },
    { id: 2, name: "كتابة رحلة تحول (3D)", price: 24 },
    { id: 3, name: "جدول المهام (112 يوم)", price: 15 },
    { id: 4, name: "نظام السيطرة على الوقت", price: 9 },
    { id: 5, name: "دفتر الامتنان الواعي", price: 12 },
    { id: 6, name: "مكتبة البودكاست التعليمية", price: 15 },
    { id: 7, name: "برنامج تحديات العناية (مع متابعة)", price: 27 },
    { id: 8, name: "جلسات الترددات الذهنية", price: 11 },
    { id: 9, name: "تمارين نشاط العقل (مع تحليل)", price: 27 },
    { id: 10, name: "نظام التخلص من العادات", price: 27 }
];

const listContainer = document.getElementById('tools-list');

evalTools.forEach(tool => {
    listContainer.innerHTML += `
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-bottom: 1px solid #f0f0f0;">
            <label style="display: flex; align-items: center; cursor: pointer;">
                <input type="checkbox" class="tool-checkbox" value="${tool.price}" data-name="${tool.name}" onchange="calculateBundle()" style="margin-left: 15px; transform: scale(1.3);">
                <span>${tool.name}</span>
            </label>
            <span style="font-weight: bold; color: #555;">$${tool.price}</span>
        </div>
    `;
});

function calculateBundle() {
    const checkboxes = document.querySelectorAll('.tool-checkbox:checked');
    let total = 0;
    checkboxes.forEach(cb => total += parseFloat(cb.value));

    const summary = document.getElementById('price-summary');
    const btn = document.getElementById('send-request-btn');

    if (checkboxes.length >= 2) {
        const discount = total * 0.85;
        summary.style.display = 'block';
        document.getElementById('total-price').innerHTML = `المجموع الأصلي: <strike>$${total.toFixed(2)}</strike>`;
        document.getElementById('discount-price').innerHTML = `السعر بعد الخصم (15%): $${discount.toFixed(2)}`;
        btn.style.display = 'inline-block';
    } else if (checkboxes.length === 1) {
        summary.style.display = 'block';
        document.getElementById('total-price').innerHTML = `المجموع: $${total.toFixed(2)}`;
        document.getElementById('discount-price').innerHTML = `أضف أداة أخرى للحصول على الخصم!`;
        btn.style.display = 'none';
    } else {
        summary.style.display = 'none';
        btn.style.display = 'none';
    }
}

function openRequestForm() {
    const selectedTools = Array.from(document.querySelectorAll('.tool-checkbox:checked')).map(cb => cb.getAttribute('data-name')).join(', ');
    const emailSubject = encodeURIComponent("طلب باقة مخصصة من إيفال");
    const emailBody = encodeURIComponent(`مرحباً فريق إيفال،\n\nأود طلب الباقة المخصصة التي تحتوي على الأدوات التالية:\n${selectedTools}\n\nبانتظار كود الخصم ورابط الدفع.\nوشكراً.`);
    window.location.href = `mailto:support@evallsuccess.com?subject=${emailSubject}&body=${emailBody}`;
}
</script>
